# ===== Koto — Environment Variable Reference =====
#
# Copy this file to the project root as ".env" before running docker compose:
#   cp config/deploy/.env.example .env
#
# Lines starting with '#' are comments. Uncomment and set values as needed.

# ─── Required ────────────────────────────────────────────────────────────────

# Deployment mode: "local" (desktop/dev) or "cloud" (production server)
KOTO_DEPLOY_MODE=cloud

# JWT signing secret — MUST be a long, random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
KOTO_JWT_SECRET=change-me-to-a-random-secret

# At least one AI provider API key is required.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Networking ──────────────────────────────────────────────────────────────

# Port exposed on the Docker host (container always listens on 5000 internally)
# KOTO_PORT=5000

# CORS allowed origins (default: "*"; restrict in production)
# KOTO_CORS_ORIGINS=https://your-domain.com

# Public-facing URL (used for auth callbacks, etc.)
# KOTO_SITE_URL=https://your-domain.com

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# KOTO_LOG_LEVEL=INFO

# Log format: "text" (human-friendly) or "json" (structured, for log aggregators)
# KOTO_LOG_FORMAT=text

# ─── Observability ───────────────────────────────────────────────────────────

# Sentry DSN for error tracking
# SENTRY_DSN=

# Sentry traces sample rate (0.0–1.0, default: 0.1)
# SENTRY_TRACES_RATE=0.1

# Metrics bearer token (for /metrics endpoint)
# METRICS_TOKEN=

# LangChain / LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxx
# LANGCHAIN_PROJECT=Koto
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── Rate Limiting & Security ────────────────────────────────────────────────

# Max API requests per user per day
# KOTO_MAX_DAILY_REQUESTS=100

# Admin token for privileged endpoints
# KOTO_ADMIN_TOKEN=

# JWT expiry in hours (default: 72)
# KOTO_JWT_EXPIRY_HOURS=72

# ─── AI Model Configuration ─────────────────────────────────────────────────

# Decision layer model (default: gemini-2.5-flash)
# KOTO_DECISION_MODEL=gemini-2.5-flash

# Gemini-specific overrides
# GEMINI_API_KEY=        # if different from GOOGLE_API_KEY
# GEMINI_API_BASE=       # custom endpoint URL

# Ollama (local models)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Email (optional) ───────────────────────────────────────────────────────

# SMTP settings for email notifications
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASS=

# ─── Development / Debug ─────────────────────────────────────────────────────

# Enable Swagger UI at /api/docs
# SWAGGER_ENABLED=false

# Debug mode (verbose logging, auto-reload — never enable in production)
# KOTO_DEBUG=false

# Proxy settings (auto = detect system proxy)
# FORCE_PROXY=auto
# HTTP_PROXY=
# HTTPS_PROXY=
