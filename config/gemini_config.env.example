# Koto 环境变量配置模板
# 复制为 gemini_config.env 并填入真实值

# ── 必须 ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_api_key_here
GEMINI_API_BASE=
FORCE_PROXY=auto

# ── LangSmith 可观测性追踪（可选）─────────────────────────────────────────────
# 获取 API Key: https://smith.langchain.com → Settings → API Keys
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxx
# LANGCHAIN_PROJECT=Koto
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # 默认，企业私有部署时修改

# ── 检查点持久化路径（可选）────────────────────────────────────────────────────
# KOTO_DB_DIR=/path/to/data   # 默认: config/ 目录

# ── 开发机专用：LoRA 蒸馏训练 API（普通用户无需开启）──────────────────────────
# 需要 ≥16GB VRAM，普通用户设备无法运行，公共发行版保持注释
# KOTO_DEV_TRAINING=1
