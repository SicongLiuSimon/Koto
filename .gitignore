# ===== Koto .gitignore =====

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
build/*.spec

# Virtual environment
.venv/
venv/
env/

# Secrets & API keys
**/gemini_config.env
config/user_settings.json
config/user_profile.json
config/memory.json
config/token_usage.json
config/skill_bindings.json
config/model_setup_done.json
config/koto_checkpoints.sqlite*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Logs
logs/
*.log

# Koto runtime temp files
_probe*.txt
_probe*.py
.koto.lock
test_output.txt
test_doc_output.txt
test_e2e.txt
build_log.txt

# Workspace user data
workspace/
chats/

# Models (large binary files)
models/

# Build artifacts
_archive/
archive/build_logs/
archive/installer_backup/
*.zip
*.exe

# Large binary files
*.fst
*.mdl
*.pdf
*.pptx
*.docx
*.xlsx

# User auth data
config/users.json

# User uploads
web/uploads/

# Node modules (if any)
node_modules/
