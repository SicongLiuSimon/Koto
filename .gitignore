# ===== Koto .gitignore =====

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
build/*.spec
# 例外：Inno Setup 中文语言文件需要随源码一起提交（CI 构建安装包依赖它）
!build/ChineseSimplified.isl

# Virtual environment
.venv/
venv/
env/

# Secrets & API keys
**/gemini_config.env
config/user_settings.json
config/user_profile.json
config/memory.json
config/token_usage.json
config/skill_bindings.json
config/model_setup_done.json
config/koto_checkpoints.sqlite*
config/local_model_prompted.json

# Runtime / personal data (generated at runtime, not for repo)
config/proactive_queue.json
config/shadow_observations.json
config/notifications.db
config/proactive_dialogue.db
config/proactive_triggers.db
config/insights.db
config/context_awareness.db
config/knowledge_graph.db
config/concepts.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Logs
logs/
*.log

# Koto runtime temp files
_probe*.txt
_probe*.py
.koto.lock
test_output.txt
test_doc_output.txt
test_e2e.txt
build_log.txt

# Workspace user data
workspace/
chats/

# Models (large binary files)
models/

# Build artifacts
_archive/
archive/build_logs/
archive/installer_backup/
*.zip
*.exe

# Large binary files
*.fst
*.mdl
*.pdf
*.pptx
*.docx
*.xlsx

# User auth data
config/users.json

# User uploads
web/uploads/

# Node modules (if any)
node_modules/

# WebView2 runtime profile
.webview2_profile/
